[Unit]
Description=SightHub Backend — DEV (Go, HTTP)
After=network-online.target postgresql.service redis-server.service
Wants=network-online.target

[Service]
Type=simple
User=sighthub-backend
Group=sighthub-backend
WorkingDirectory=/home/aleks/sighthub-backend

Environment=APP_ENV=development
Environment=CONFIG_FILE=/home/aleks/sighthub-backend/config/config.development.json

ExecStart=/home/aleks/sighthub-backend/sighthub-backend
ExecReload=/bin/kill -HUP $MAINPID

Restart=always
RestartSec=2s
KillSignal=SIGTERM
TimeoutStopSec=30
KillMode=mixed

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false

[Install]
WantedBy=multi-user.target
